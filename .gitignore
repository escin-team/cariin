--- .gitignore (原始)
```
# Dependencies
node_modules/
```

+++ .gitignore (修改后)
```
# Dependencies
node_modules/

# Build artifacts
dist/
build/
.next/
out/

# Environment variables
.env
.env.local
.env.*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled CSS/JS
*.min.css
*.min.js

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Images (not ignored as per rules)
# *.png, *.jpg, *.jpeg, *.bmp, *.gif, *.webm are NOT ignored

```